# --- App ---
PORT=3000
PUBLIC_URL=https://dental-fortes-crm.vercel.app

# --- Supabase ---
# IMPORTANTE: usa la service_role key, NO la anon. Sin path al final (sin /rest/v1/).
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...service_role...

# --- Admin ---
# Contraseña para el login del panel /admin (la valida bcrypt en lib/auth.js).
# Genera la suya con: node -e "console.log(require('bcryptjs').hashSync('TU_PASSWORD', 10))"
ADMIN_PASSWORD_HASH=$2a$10$REEMPLAZAR_POR_HASH_BCRYPT

# Clave para firmar las cookies/sesiones del admin (cualquier cadena larga aleatoria).
SESSION_SECRET=cambia_esto_por_una_cadena_aleatoria_larga

# --- Bot (placeholders para fase 2) ---
# ANTHROPIC_API_KEY=
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_APP_SECRET=
