# --- App ---
PORT=3000
PUBLIC_URL=https://dental-fortes-crm.vercel.app

# --- Supabase ---
# IMPORTANTE: usa la service_role key, NO la anon. Sin path al final (sin /rest/v1/).
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...service_role...

# --- Admin ---
# Contraseña para el login del panel /admin (la valida bcrypt en lib/auth.js).
# Genera la suya con: node -e "console.log(require('bcryptjs').hashSync('TU_PASSWORD', 10))"
ADMIN_PASSWORD_HASH=$2a$10$REEMPLAZAR_POR_HASH_BCRYPT

# Clave para firmar las cookies/sesiones del admin (cualquier cadena larga aleatoria).
SESSION_SECRET=cambia_esto_por_una_cadena_aleatoria_larga

# --- Bot: Claude (Fase 2) ---
# API key de Anthropic para el chatbot. Sin ella, el bot responde con un mensaje
# de "en breve le atiende una persona" (no se cae nada).
ANTHROPIC_API_KEY=sk-ant-...
# Modelo del bot. Por defecto claude-opus-4-8. Para un bot de alto volumen por
# WhatsApp, claude-haiku-4-5 (más barato/rápido) o claude-sonnet-5 suelen bastar.
# ANTHROPIC_MODEL=claude-opus-4-8
# ANTHROPIC_MAX_TOKENS=1024

# --- Bot: WhatsApp Cloud API (Fase 2b / 7) ---
# Versión Graph API usada por WhatsApp/Meta. Déjala vacía para usar la del código.
# META_GRAPH_VERSION=v21.0
# WHATSAPP_TOKEN=
# WABA ID / WhatsApp Business Account ID. Necesario para crear plantillas desde el CRM.
# WHATSAPP_BUSINESS_ACCOUNT_ID=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_APP_SECRET=
